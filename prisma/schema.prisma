generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
  MANUFACTURER
}

enum SupplierStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum QuoteStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum ReturnStatus {
  OPEN
  APPROVED
  REJECTED
  RESOLVED
}

enum PayoutStatus {
  DUE
  PROCESSING
  PAID
  FAILED
}

enum SupplierMemberRole {
  OWNER
  ADMIN
  SALES
  FULFILLMENT
  CATALOG
  FINANCE
  VIEWER
}

model User {
  id                         String               @id @default(cuid())
  email                      String               @unique
  passwordHash               String
  name                       String
  role                       Role                 @default(BUYER)
  manufacturerName           String?
  // Partial unique index on (manufacturerName) where role='MANUFACTURER'
  // is enforced by migration 20260607000000_unique_oem_manufacturer_name.
  // Prisma doesn't model partial uniques natively.
  manufacturerTagline        String               @default("")
  manufacturerBio            String               @default("")
  manufacturerLogoUrl        String?
  manufacturerWebsite        String               @default("")
  // Buyer company profile (B2B). Shown on checkout, order detail, invoice,
  // and in the shipped/paid emails when set. Optional; guest checkout
  // doesn't get this.
  companyName                String?
  companyLogoUrl             String?
  totpSecret                 String?
  totpEnabledAt              DateTime?
  totpBackupCodes            Json?
  // Email verification. emailVerified is null until the user clicks the
  // link in the welcome email; verified buyers/suppliers can complete
  // state-changing flows (orders, listings). The token + expiry are
  // cleared on success or on resend.
  emailVerified              DateTime?
  // PLH-1: verify token is hashed at rest (SHA-256, hex). The raw token only
  // appears in the URL we email and in memory between generation and send.
  // Mirrors PasswordResetToken / AccountToken.
  emailVerificationTokenHash String?              @unique
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  // PLH-1: bumped on password change, password reset, 2FA disable, email
  // change confirmation, and account self-delete. Every existing session
  // cookie issued before this timestamp is rejected on the next request.
  sessionsValidFrom          DateTime             @default(now())
  // Soft delete for GDPR/CCPA. When set, PII is anonymized but order
  // history is retained for tax/accounting. Hard-delete happens after
  // 30 days unless the user recovers.
  deletedAt                  DateTime?
  // PLH-1 commit 2: set by the anonymize-deleted-accounts cron 30 days
  // after deletedAt. After this point, email and name are scrubbed but
  // Order rows remain intact for tax/accounting.
  anonymizedAt               DateTime?
  supplier                   Supplier?
  orders                     Order[]
  resetTokens                PasswordResetToken[]
  reviews                    Review[]
  addresses                  Address[]
  messages                   Message[]
  supplierMemberships        SupplierMember[]
  // PLH-2 Phase 4d (D1): CAN-SPAM opt-out gates for non-transactional
  // mail. Transactional emails (auth, password reset, order
  // confirmation, payment receipt, refund, return, payout failure,
  // 2FA, security alerts) always send and bypass these flags. These
  // three only gate marketing-ish broadcasts.
  notifyOrderEmails          Boolean              @default(true)
  notifyMarketingEmails      Boolean              @default(true)
  notifyProductUpdates       Boolean              @default(true)
  createdAt                  DateTime             @default(now())
  accountTokens              AccountToken[]
  // PLH-3c F3: OEM approval gate. A MANUFACTURER user submits a
  // ManufacturerApplication when they pick a brand name; admin must
  // APPROVE it before User.manufacturerName is written and the
  // storefront becomes live.
  manufacturerApplication    ManufacturerApplication?
  reviewedManufacturerApps   ManufacturerApplication[] @relation("ReviewedManufacturerApps")
}

/**
 * Single-use account tokens for sensitive flows that have to go through
 * a confirmation email round-trip: changing the sign-in email and
 * undoing a soft-deleted account during the grace period. Pattern
 * matches PasswordResetToken (tokenHash stored at rest).
 */
model AccountToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Hex-encoded SHA-256 of the random token. The raw token only ever
  // appears in the URL emailed to the user.
  tokenHash String    @unique
  // EMAIL_CHANGE | ACCOUNT_RECOVERY
  type      String
  payload   Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([type])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Review {
  id           String    @id @default(cuid())
  buyer        User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId      String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId   String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  rating       Int
  title        String    @default("")
  body         String    @default("")
  hiddenAt     DateTime?
  hiddenReason String    @default("")
  hiddenById   String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, productId, orderId])
  @@index([productId])
  @@index([supplierId])
  @@index([orderId])
}

model Address {
  id                      String   @id @default(cuid())
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                  String
  label                   String   @default("")
  recipient               String
  company                 String   @default("")
  line1                   String
  line2                   String   @default("")
  city                    String
  region                  String
  postalCode              String
  country                 String   @default("US")
  phone                   String   @default("")
  isDefault               Boolean  @default(false)
  // Tax-exempt buyers can upload a resale or government-entity certificate.
  // When present and APPROVED, Stripe Tax (or any tax engine) skips
  // computation on the order. Admin reviews the cert before approval.
  taxExemptCertificateUrl String?
  taxExemptStatus         String? // "PENDING" | "APPROVED" | "REJECTED" | null
  createdAt               DateTime @default(now())

  @@index([userId])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model Supplier {
  id                String             @id @default(cuid())
  name              String
  contactEmail      String
  status            SupplierStatus     @default(APPROVED)
  rating            Float              @default(4.7)
  reviews           Int                @default(0)
  onTimeRate        Float              @default(97.5)
  certifications    String             @default("")
  logoUrl           String?
  website           String             @default("")
  description       String             @default("")
  // Go-live gate. Defaults to false. The supplier's products are filtered
  // out of the public catalog, the home page, brand storefronts, search,
  // and the sitemap until an admin flips this to true (typically after the
  // 10-item onboarding checklist passes: legal docs approved, bank info
  // on file, at least one product). See lib/supplier-access.ts.
  publicVisible     Boolean            @default(false)
  // LEGACY payout method summary (Polish 6). Superseded by Stripe Connect
  // in P8. Kept on existing rows for audit history but the supplier UI
  // surfaces the stripeConnect* fields below as the source of truth.
  bankInfoStatus    String             @default("MISSING") // MISSING | PENDING | ON_FILE | REJECTED
  bankInfoLast4     String?
  bankInfoType      String? // CHECKING | SAVINGS
  bankInfoBankName  String?
  bankInfoNote      String             @default("")
  bankInfoUpdatedAt DateTime?
  // Stripe Connect Express. Supplier onboards via Stripe-hosted flow; the
  // PartsPort UI just renders an "Active / Pending / Disabled" status.
  // PartsPort never touches the account or routing numbers.
  stripeAccountId              String?   @unique
  stripeChargesEnabled         Boolean   @default(false)
  stripePayoutsEnabled         Boolean   @default(false)
  stripeOnboardingCompletedAt  DateTime?
  // Reserve / chargeback holdback. Each Payout subtracts this percent of
  // the supplier subtotal before transferring; held funds accumulate in
  // reserveBalanceCents and release after 60 days via cron (P8 S6) when
  // no chargeback or refund has hit the order.
  reservePercent       Int     @default(500)   // basis points (500 = 5%)
  reserveBalanceCents  Int     @default(0)
  // P9.5: refund shortfall accounting. When a refund clears more than the
  // available reserveBalanceCents (typical for 60+ day-old orders where
  // the supplier was already paid out), the difference is added here and
  // netted against future Payouts via lib/payouts.ts. Always >= 0.
  owedToPlatformCents  Int     @default(0)
  user              User?              @relation(fields: [userId], references: [id])
  userId            String?            @unique
  products          Product[]
  productReviews    Review[]
  payouts           Payout[]
  members           SupplierMember[]
  invites           SupplierInvite[]
  documents         SupplierDocument[]
  warehouses        SupplierWarehouse[]
  createdAt         DateTime           @default(now())
}

model SupplierDocument {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  // SUPPLIER_AGREEMENT | W9 | INSURANCE_COI | OTHER. Kept as a string so we
  // can introduce new kinds without a schema migration; the API rejects
  // unknown values.
  kind       String
  filename   String
  url        String
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote String    @default("")
  reviewedAt DateTime?
  reviewedBy String?
  uploadedAt DateTime  @default(now())

  @@index([supplierId])
  @@index([status])
}

/**
 * Origin warehouse for a supplier. Real-rate freight quotes need an
 * origin zip; we let suppliers register multiple warehouses (regional
 * stock points) and pick a default. When a buyer lands on the checkout
 * page, we compute freight using each supplier's default warehouse as
 * the origin.
 */
model SupplierWarehouse {
  id         String   @id @default(cuid())
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  label      String   @default("")
  zip        String
  city       String
  state      String   // two-letter US state code
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([supplierId])
}

model SupplierMember {
  id         String             @id @default(cuid())
  supplier   Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       SupplierMemberRole @default(ADMIN)
  createdAt  DateTime           @default(now())

  @@unique([supplierId, userId])
  @@index([userId])
}

model SupplierInvite {
  id          String             @id @default(cuid())
  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  email       String
  role        SupplierMemberRole @default(ADMIN)
  tokenHash   String             @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([supplierId])
  @@index([email])
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  category      String
  manufacturer  String
  icon          String
  imageUrl      String?
  priceCents    Int
  unit          String         @default("each")
  etaDays       Int
  stock         Int            @default(0)
  quoteOnly     Boolean        @default(false)
  description   String
  specs         Json
  // Freight inputs. Populated by the supplier on the listing form (and by
  // bulk CSV import where present). When weight + dims + freightClass are
  // all set on every line of an order, real-rate Shippo quotes light up;
  // otherwise the deterministic fallback in lib/freight.ts takes over.
  // freightClass values follow NMFC (50, 55, 60, 65, 70, 77.5, 85, 92.5,
  // 100, 110, 125, 150, 175, 200, 250, 300, 400, 500); stored as a string
  // because the codes aren't sequential integers.
  weightLbs     Float?
  freightClass  String?
  lengthIn      Float?
  widthIn       Float?
  heightIn      Float?
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  supplierId    String
  active        Boolean        @default(true)
  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
  reviews       Review[]
  images        ProductImage[]
  createdAt     DateTime       @default(now())
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Payout {
  id              String       @id @default(cuid())
  reference       String       @unique
  supplier        Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId      String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  // amountCents is what the supplier actually receives: subtotal share
  // minus reserve. reservedCents records what was held back, mirrored
  // onto Order.reservedCents for the buyer-facing order view.
  amountCents     Int
  reservedCents   Int          @default(0)
  status          PayoutStatus @default(DUE)
  // Stripe transfer id for the supplier portion. Null on legacy manual
  // payouts (pre-P8) and on payouts where Connect onboarding wasn't done.
  stripeTransferId String?     @unique
  // Number of retry attempts the payout-retry cron has burned; gives the
  // cron an exponential backoff and a stopping point.
  retryAttempts   Int          @default(0)
  lastRetryAt     DateTime?
  failureReason   String       @default("")
  note            String       @default("")
  createdAt       DateTime     @default(now())
  paidAt          DateTime?

  @@unique([supplierId, orderId])
  @@index([status])
}

/**
 * Audit trail for reserve holdback. Type values:
 *   HOLD       - amount held when a payout was created
 *   RELEASE    - amount released back to the supplier after the 60-day
 *                quiet window or admin manual release
 *   DRAW_DOWN  - amount pulled from the reserve to cover a refund or
 *                chargeback
 *
 * The running supplier balance is in Supplier.reserveBalanceCents; this
 * table is the per-transaction history.
 */
model SupplierReserveTransaction {
  id          String   @id @default(cuid())
  supplierId  String
  type        String   // HOLD | RELEASE | DRAW_DOWN | OWED_INCURRED
  amountCents Int
  orderId     String?
  reason      String   @default("")
  // PLH-2 Phase 4e (E3): RELEASE rows go through a two-stage lifecycle so
  // the Stripe transfer fires AFTER the candidate is staked out but BEFORE
  // reserveBalanceCents is decremented. status values:
  //   PENDING   - row staked out before the Stripe transfer fires.
  //               reserveBalanceCents NOT yet decremented.
  //   COMPLETED - the transfer succeeded (or was skipped for non-Connect
  //               suppliers). reserveBalanceCents has been decremented.
  //   FAILED    - the transfer failed. reserveBalanceCents was NOT
  //               touched. The next cron run retries.
  // Pre-existing rows have status NULL which is treated as COMPLETED for
  // backwards compatibility. HOLD / DRAW_DOWN / OWED_INCURRED rows ignore
  // this field.
  status      String?
  createdAt   DateTime @default(now())

  @@index([supplierId])
  @@index([orderId])
  @@index([status])
}

/**
 * Stripe refund records. One row per refund (a single order can have
 * multiple partial refunds). amountCents is positive; the running total
 * is mirrored onto Order.refundedCents for fast access on the order view.
 */
model Refund {
  id              String   @id @default(cuid())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  stripeRefundId  String?  @unique
  amountCents     Int
  reason          String   @default("")
  returnRequestId String?
  refundedBy      String?  // User.id of the admin who triggered it
  status          String   @default("succeeded") // succeeded | pending | failed
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([returnRequestId])
}

model ReturnRequest {
  id         String       @id @default(cuid())
  reference  String       @unique
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  buyerId    String?
  reason     String
  details    String       @default("")
  status     ReturnStatus @default(OPEN)
  adminNote  String       @default("")
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@index([orderId])
  @@index([status])
}

model Order {
  id                  String          @id @default(cuid())
  reference           String          @unique
  status              OrderStatus     @default(PENDING)
  buyer               User?           @relation(fields: [buyerId], references: [id])
  buyerId             String?
  buyerEmail          String
  buyerName           String
  // Snapshotted from User.companyName / User.companyLogoUrl at order
  // creation time so later profile edits never retroactively rewrite a
  // past invoice's branding.
  buyerCompanyName    String?
  buyerCompanyLogoUrl String?
  shipTo              String
  // P9.5: server-side idempotency. Hash of (Idempotency-Key header or
  // body.idempotencyKey) + buyer (userId or email). Two identical POSTs
  // collide on this unique index; the second POST returns the existing
  // order id instead of creating a duplicate. Pre-P9.5 the route had no
  // dedupe and the verify chat confirmed duplicates were being created.
  idempotencyKey      String?         @unique
  subtotalCents       Int
  freightCents        Int             @default(0)
  feeCents            Int
  taxCents            Int             @default(0)
  totalCents          Int
  feeRateBps          Int             @default(600)
  paymentMethod       String          @default("paypal")
  paypalOrderId       String?
  // Stripe payment_intent id captured from the checkout session webhook.
  // Required for the Stripe refund flow (P8 S4).
  stripePaymentIntentId String?
  // Running totals updated transactionally:
  //   refundedCents: sum of Refund rows; flips Order to REFUNDED at full.
  //   reservedCents: mirror of sum(Payout.reservedCents) for this order.
  refundedCents       Int             @default(0)
  reservedCents       Int             @default(0)
  // P9 freight. freightCarrier/Service: label for the chosen rate.
  // freightBreakdown: when the cart spans multiple suppliers, this is
  // the per-supplier-shipment array (carrier, service, cents, originZip).
  // freightSurcharges: { liftgate, residential, insideDelivery } booleans
  // (P9 S4). Stored as JSON to avoid a migration per new surcharge type.
  freightCarrier      String?
  freightService      String?
  freightBreakdown    Json?
  freightSurcharges   Json?
  // P9.5: Shippo labels. shippoLabels is an array of { supplierId,
  // labelUrl, trackingNumber, carrier, service, transactionId } - one
  // per shipment, mirrors freightBreakdown. P9 S5 only stored a single
  // carrier+tracking on top-level fields; multi-supplier orders need
  // per-shipment labels. Existing single-supplier orders keep using the
  // top-level carrier + trackingCode fields.
  shippoLabels        Json?
  shipmentStage       String          @default("")
  carrier             String?
  trackingCode        String?
  // PLH-3a B1: real ship timestamp set inside markOrderShipped() when an
  // order transitions to shipmentStage = "Shipped". Idempotent (only set
  // when null). Supplier-health uses this for accurate avg days-to-ship
  // instead of approximating with createdAt.
  shippedAt           DateTime?
  // PLH-2 Phase 4e (E2): set when sendOrderDelivered fires successfully
  // after the auto-deliver cron flips the order. If the email throws, this
  // stays null and the AUTO_DELIVER_EMAIL_FAILED audit row is the trail.
  deliveryEmailSentAt DateTime?
  items               OrderItem[]
  invoice             Invoice?
  returns             ReturnRequest[]
  payouts             Payout[]
  refunds             Refund[]
  messages            Message[]
  reviews             Review[]
  createdAt           DateTime        @default(now())
  paidAt              DateTime?
  cancelledAt         DateTime?
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String        @unique
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  subtotalCents Int
  freightCents  Int
  feeCents      Int
  taxCents      Int
  totalCents    Int
  buyerName     String
  buyerEmail    String
  shipTo        String
}

model OrderItem {
  id             String  @id @default(cuid())
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  product        Product @relation(fields: [productId], references: [id])
  productId      String
  nameSnapshot   String
  skuSnapshot    String
  supplierName   String
  unitPriceCents Int
  qty            Int
}

model QuoteRequest {
  id              String      @id @default(cuid())
  reference       String      @unique
  product         Product     @relation(fields: [productId], references: [id])
  productId       String
  qty             Int         @default(1)
  buyerId         String?
  buyerName       String
  buyerEmail      String
  company         String      @default("")
  message         String      @default("")
  status          QuoteStatus @default(OPEN)
  quotedUnitCents Int?
  quoteNote       String      @default("")
  // Polish 12 H1: quotes default to a 30-day window once priced. The
  // accept endpoint returns 410 past expiry; the buyer-facing quote
  // page surfaces "Quote expires in N days".
  quoteExpiresAt  DateTime?
  // Polish 12 H2: unique so concurrent /accept POSTs can't write two
  // different Order ids onto the same quote. The create-order +
  // update-quote wrapper catches P2002 and returns the existing
  // winner's orderId (idempotent 200).
  orderId         String?     @unique
  messages        Message[]
  createdAt       DateTime    @default(now())
  quotedAt        DateTime?
}

model Message {
  id          String        @id @default(cuid())
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String?
  quote       QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String?
  sender      User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderId    String?
  senderName  String
  senderEmail String
  senderRole  String
  body        String
  createdAt   DateTime      @default(now())
  inboundFingerprint String? @unique

  @@index([orderId])
  @@index([quoteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String
  // Free-form string instead of an enum so we can introduce new actions
  // without a schema migration. Set of well-known values is enforced at
  // the lib/audit.ts boundary.
  action     String
  targetType String
  targetId   String
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/**
 * Per-US-state tax registration tracker. Stripe Tax computes liability
 * automatically; this table records where PartsPort has actually
 * registered to remit. Used by /admin/tax-registrations.
 */
model TaxRegistration {
  id                 String    @id @default(cuid())
  state              String    @unique  // "TX" | "CA" | etc.
  registrationStatus String    // NOT_REQUIRED | REQUIRED | REGISTERED | FILING
  registeredAt       DateTime?
  nextFilingDue      DateTime?
  notes              String    @default("")
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())
}

/**
 * PLH-2 Phase 4e (E5): singleton row tracking the reconcile cron cursor.
 * The reconcile cron walks Stripe charges and transfers in 7-day chunks
 * starting from `cursor`. On success it advances `cursor` to the end of
 * the processed window. A long outage catches up over multiple runs
 * instead of silently losing any data beyond Stripe's 7-day default.
 * Singleton: one row with id = "singleton".
 */
model ReconciliationState {
  id        String   @id @default("singleton")
  cursor    DateTime?
  updatedAt DateTime @updatedAt
}

/// PLH-3c F3: OEM approval gate. Anyone signing up as MANUFACTURER must
/// submit a brand name for admin review; the public storefront and the
/// claimed-brand dropdown only surface APPROVED rows. Existing
/// manufacturerName users are auto-backfilled to APPROVED in the
/// 20260607010000 migration.
model ManufacturerApplication {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  manufacturerName String
  status           MfgAppStatus @default(PENDING)
  submittedAt      DateTime     @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedBy       User?        @relation("ReviewedManufacturerApps", fields: [reviewedByUserId], references: [id])
  rejectionReason  String?

  @@index([status])
}

enum MfgAppStatus {
  PENDING
  APPROVED
  REJECTED
}

model SupplierApplication {
  id           String            @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  website      String            @default("")
  category     String
  yearsTrading String
  certs        String            @default("")
  message      String            @default("")
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
}
