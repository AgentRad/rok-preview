generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
  MANUFACTURER
}

enum SupplierStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
}

enum QuoteStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum ReturnStatus {
  OPEN
  APPROVED
  REJECTED
  RESOLVED
}

enum PayoutStatus {
  DUE
  PAID
}

enum SupplierMemberRole {
  OWNER
  ADMIN
  SALES
  FULFILLMENT
  CATALOG
  FINANCE
  VIEWER
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String
  role                Role     @default(BUYER)
  manufacturerName    String?
  manufacturerTagline String   @default("")
  manufacturerBio     String   @default("")
  manufacturerLogoUrl String?
  manufacturerWebsite String   @default("")
  // Buyer company profile (B2B). Shown on checkout, order detail, invoice,
  // and in the shipped/paid emails when set. Optional; guest checkout
  // doesn't get this.
  companyName         String?
  companyLogoUrl      String?
  totpSecret          String?
  totpEnabledAt       DateTime?
  totpBackupCodes     Json?
  // Email verification. emailVerified is null until the user clicks the
  // link in the welcome email; verified buyers/suppliers can complete
  // state-changing flows (orders, listings). The token + expiry are
  // cleared on success or on resend.
  emailVerified                DateTime?
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  emailVerificationSentAt      DateTime?
  // Soft delete for GDPR/CCPA. When set, PII is anonymized but order
  // history is retained for tax/accounting. Hard-delete happens after
  // 30 days unless the user recovers.
  deletedAt           DateTime?
  supplier            Supplier?
  orders              Order[]
  resetTokens         PasswordResetToken[]
  reviews             Review[]
  addresses           Address[]
  messages            Message[]
  supplierMemberships SupplierMember[]
  createdAt           DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Review {
  id           String    @id @default(cuid())
  buyer        User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId      String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId   String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  rating       Int
  title        String    @default("")
  body         String    @default("")
  hiddenAt     DateTime?
  hiddenReason String    @default("")
  hiddenById   String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, productId, orderId])
  @@index([productId])
  @@index([supplierId])
  @@index([orderId])
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String   @default("")
  recipient  String
  company    String   @default("")
  line1      String
  line2      String   @default("")
  city       String
  region     String
  postalCode String
  country    String   @default("US")
  phone      String   @default("")
  isDefault  Boolean  @default(false)
  // Tax-exempt buyers can upload a resale or government-entity certificate.
  // When present and APPROVED, Stripe Tax (or any tax engine) skips
  // computation on the order. Admin reviews the cert before approval.
  taxExemptCertificateUrl String?
  taxExemptStatus         String?  // "PENDING" | "APPROVED" | "REJECTED" | null
  createdAt  DateTime @default(now())

  @@index([userId])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model Supplier {
  id             String         @id @default(cuid())
  name           String
  contactEmail   String
  status         SupplierStatus @default(APPROVED)
  rating         Float          @default(4.7)
  reviews        Int            @default(0)
  onTimeRate     Float          @default(97.5)
  certifications String         @default("")
  logoUrl        String?
  website        String         @default("")
  description    String         @default("")
  // Go-live gate. Defaults to false. The supplier's products are filtered
  // out of the public catalog, the home page, brand storefronts, search,
  // and the sitemap until an admin flips this to true (typically after the
  // 10-item onboarding checklist passes: legal docs approved, bank info
  // on file, at least one product). See lib/supplier-access.ts.
  publicVisible  Boolean        @default(false)
  // Payout method summary. PartsPort does NOT store full account or routing
  // numbers; suppliers send those via secure channel and admin flips the
  // status to ON_FILE once received.
  bankInfoStatus     String    @default("MISSING") // MISSING | PENDING | ON_FILE | REJECTED
  bankInfoLast4      String?
  bankInfoType       String?   // CHECKING | SAVINGS
  bankInfoBankName   String?
  bankInfoNote       String    @default("")
  bankInfoUpdatedAt  DateTime?
  user           User?          @relation(fields: [userId], references: [id])
  userId         String?        @unique
  products       Product[]
  productReviews Review[]
  payouts        Payout[]
  members        SupplierMember[]
  invites        SupplierInvite[]
  documents      SupplierDocument[]
  createdAt      DateTime       @default(now())
}

model SupplierDocument {
  id          String   @id @default(cuid())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  // SUPPLIER_AGREEMENT | W9 | INSURANCE_COI | OTHER. Kept as a string so we
  // can introduce new kinds without a schema migration; the API rejects
  // unknown values.
  kind        String
  filename    String
  url         String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote  String   @default("")
  reviewedAt  DateTime?
  reviewedBy  String?
  uploadedAt  DateTime @default(now())

  @@index([supplierId])
  @@index([status])
}

model SupplierMember {
  id         String             @id @default(cuid())
  supplier   Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       SupplierMemberRole @default(ADMIN)
  createdAt  DateTime           @default(now())

  @@unique([supplierId, userId])
  @@index([userId])
}

model SupplierInvite {
  id          String             @id @default(cuid())
  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  email       String
  role        SupplierMemberRole @default(ADMIN)
  tokenHash   String             @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([supplierId])
  @@index([email])
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  category      String
  manufacturer  String
  icon          String
  imageUrl      String?
  priceCents    Int
  unit          String         @default("each")
  etaDays       Int
  stock         Int            @default(0)
  quoteOnly     Boolean        @default(false)
  description   String
  specs         Json
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  supplierId    String
  active        Boolean        @default(true)
  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
  reviews       Review[]
  images        ProductImage[]
  createdAt     DateTime       @default(now())
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Payout {
  id          String       @id @default(cuid())
  reference   String       @unique
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  amountCents Int
  status      PayoutStatus @default(DUE)
  note        String       @default("")
  createdAt   DateTime     @default(now())
  paidAt      DateTime?

  @@unique([supplierId, orderId])
  @@index([status])
}

model ReturnRequest {
  id           String       @id @default(cuid())
  reference    String       @unique
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  buyerId      String?
  reason       String
  details      String       @default("")
  status       ReturnStatus @default(OPEN)
  adminNote    String       @default("")
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?

  @@index([orderId])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  reference     String      @unique
  status        OrderStatus @default(PENDING)
  buyer         User?       @relation(fields: [buyerId], references: [id])
  buyerId       String?
  buyerEmail    String
  buyerName     String
  // Snapshotted from User.companyName / User.companyLogoUrl at order
  // creation time so later profile edits never retroactively rewrite a
  // past invoice's branding.
  buyerCompanyName String?
  buyerCompanyLogoUrl String?
  shipTo        String
  subtotalCents Int
  freightCents  Int         @default(0)
  feeCents      Int
  taxCents      Int         @default(0)
  totalCents    Int
  feeRateBps    Int         @default(600)
  paymentMethod String      @default("paypal")
  paypalOrderId String?
  shipmentStage String      @default("")
  carrier       String?
  trackingCode  String?
  items         OrderItem[]
  invoice       Invoice?
  returns       ReturnRequest[]
  payouts       Payout[]
  messages      Message[]
  reviews       Review[]
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String        @unique
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  subtotalCents Int
  freightCents  Int
  feeCents      Int
  taxCents      Int
  totalCents    Int
  buyerName     String
  buyerEmail    String
  shipTo        String
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product @relation(fields: [productId], references: [id])
  productId    String
  nameSnapshot String
  skuSnapshot  String
  supplierName String
  unitPriceCents Int
  qty          Int
}

model QuoteRequest {
  id              String      @id @default(cuid())
  reference       String      @unique
  product         Product     @relation(fields: [productId], references: [id])
  productId       String
  qty             Int         @default(1)
  buyerId         String?
  buyerName       String
  buyerEmail      String
  company         String      @default("")
  message         String      @default("")
  status          QuoteStatus @default(OPEN)
  quotedUnitCents Int?
  quoteNote       String      @default("")
  orderId         String?
  messages        Message[]
  createdAt       DateTime    @default(now())
  quotedAt        DateTime?
}

model Message {
  id          String        @id @default(cuid())
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String?
  quote       QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String?
  sender      User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderId    String?
  senderName  String
  senderEmail String
  senderRole  String
  body        String
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@index([quoteId])
}

model SupplierApplication {
  id           String            @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  website      String            @default("")
  category     String
  yearsTrading String
  certs        String            @default("")
  message      String            @default("")
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
}
