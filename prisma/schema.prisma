generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
  MANUFACTURER
}

enum SupplierStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum QuoteStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum ReturnStatus {
  OPEN
  APPROVED
  REJECTED
  RESOLVED
}

enum PayoutStatus {
  DUE
  PROCESSING
  PAID
  FAILED
}

enum SupplierMemberRole {
  OWNER
  ADMIN
  SALES
  FULFILLMENT
  CATALOG
  FINANCE
  VIEWER
}

model User {
  id                         String               @id @default(cuid())
  email                      String               @unique
  passwordHash               String
  name                       String
  role                       Role                 @default(BUYER)
  manufacturerName           String?
  manufacturerTagline        String               @default("")
  manufacturerBio            String               @default("")
  manufacturerLogoUrl        String?
  manufacturerWebsite        String               @default("")
  // Buyer company profile (B2B). Shown on checkout, order detail, invoice,
  // and in the shipped/paid emails when set. Optional; guest checkout
  // doesn't get this.
  companyName                String?
  companyLogoUrl             String?
  totpSecret                 String?
  totpEnabledAt              DateTime?
  totpBackupCodes            Json?
  // Email verification. emailVerified is null until the user clicks the
  // link in the welcome email; verified buyers/suppliers can complete
  // state-changing flows (orders, listings). The token + expiry are
  // cleared on success or on resend.
  emailVerified              DateTime?
  emailVerificationToken     String?              @unique
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  // Soft delete for GDPR/CCPA. When set, PII is anonymized but order
  // history is retained for tax/accounting. Hard-delete happens after
  // 30 days unless the user recovers.
  deletedAt                  DateTime?
  supplier                   Supplier?
  orders                     Order[]
  resetTokens                PasswordResetToken[]
  reviews                    Review[]
  addresses                  Address[]
  messages                   Message[]
  supplierMemberships        SupplierMember[]
  createdAt                  DateTime             @default(now())
  accountTokens              AccountToken[]
}

/**
 * Single-use account tokens for sensitive flows that have to go through
 * a confirmation email round-trip: changing the sign-in email and
 * undoing a soft-deleted account during the grace period. Pattern
 * matches PasswordResetToken (tokenHash stored at rest).
 */
model AccountToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Hex-encoded SHA-256 of the random token. The raw token only ever
  // appears in the URL emailed to the user.
  tokenHash String    @unique
  // EMAIL_CHANGE | ACCOUNT_RECOVERY
  type      String
  payload   Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([type])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Review {
  id           String    @id @default(cuid())
  buyer        User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId      String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId   String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  rating       Int
  title        String    @default("")
  body         String    @default("")
  hiddenAt     DateTime?
  hiddenReason String    @default("")
  hiddenById   String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, productId, orderId])
  @@index([productId])
  @@index([supplierId])
  @@index([orderId])
}

model Address {
  id                      String   @id @default(cuid())
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                  String
  label                   String   @default("")
  recipient               String
  company                 String   @default("")
  line1                   String
  line2                   String   @default("")
  city                    String
  region                  String
  postalCode              String
  country                 String   @default("US")
  phone                   String   @default("")
  isDefault               Boolean  @default(false)
  // Tax-exempt buyers can upload a resale or government-entity certificate.
  // When present and APPROVED, Stripe Tax (or any tax engine) skips
  // computation on the order. Admin reviews the cert before approval.
  taxExemptCertificateUrl String?
  taxExemptStatus         String? // "PENDING" | "APPROVED" | "REJECTED" | null
  createdAt               DateTime @default(now())

  @@index([userId])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model Supplier {
  id                String             @id @default(cuid())
  name              String
  contactEmail      String
  status            SupplierStatus     @default(APPROVED)
  rating            Float              @default(4.7)
  reviews           Int                @default(0)
  onTimeRate        Float              @default(97.5)
  certifications    String             @default("")
  logoUrl           String?
  website           String             @default("")
  description       String             @default("")
  // Go-live gate. Defaults to false. The supplier's products are filtered
  // out of the public catalog, the home page, brand storefronts, search,
  // and the sitemap until an admin flips this to true (typically after the
  // 10-item onboarding checklist passes: legal docs approved, bank info
  // on file, at least one product). See lib/supplier-access.ts.
  publicVisible     Boolean            @default(false)
  // LEGACY payout method summary (Polish 6). Superseded by Stripe Connect
  // in P8. Kept on existing rows for audit history but the supplier UI
  // surfaces the stripeConnect* fields below as the source of truth.
  bankInfoStatus    String             @default("MISSING") // MISSING | PENDING | ON_FILE | REJECTED
  bankInfoLast4     String?
  bankInfoType      String? // CHECKING | SAVINGS
  bankInfoBankName  String?
  bankInfoNote      String             @default("")
  bankInfoUpdatedAt DateTime?
  // Stripe Connect Express. Supplier onboards via Stripe-hosted flow; the
  // PartsPort UI just renders an "Active / Pending / Disabled" status.
  // PartsPort never touches the account or routing numbers.
  stripeAccountId              String?   @unique
  stripeChargesEnabled         Boolean   @default(false)
  stripePayoutsEnabled         Boolean   @default(false)
  stripeOnboardingCompletedAt  DateTime?
  // Reserve / chargeback holdback. Each Payout subtracts this percent of
  // the supplier subtotal before transferring; held funds accumulate in
  // reserveBalanceCents and release after 60 days via cron (P8 S6) when
  // no chargeback or refund has hit the order.
  reservePercent       Int     @default(500)   // basis points (500 = 5%)
  reserveBalanceCents  Int     @default(0)
  user              User?              @relation(fields: [userId], references: [id])
  userId            String?            @unique
  products          Product[]
  productReviews    Review[]
  payouts           Payout[]
  members           SupplierMember[]
  invites           SupplierInvite[]
  documents         SupplierDocument[]
  createdAt         DateTime           @default(now())
}

model SupplierDocument {
  id         String    @id @default(cuid())
  supplier   Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  // SUPPLIER_AGREEMENT | W9 | INSURANCE_COI | OTHER. Kept as a string so we
  // can introduce new kinds without a schema migration; the API rejects
  // unknown values.
  kind       String
  filename   String
  url        String
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote String    @default("")
  reviewedAt DateTime?
  reviewedBy String?
  uploadedAt DateTime  @default(now())

  @@index([supplierId])
  @@index([status])
}

model SupplierMember {
  id         String             @id @default(cuid())
  supplier   Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       SupplierMemberRole @default(ADMIN)
  createdAt  DateTime           @default(now())

  @@unique([supplierId, userId])
  @@index([userId])
}

model SupplierInvite {
  id          String             @id @default(cuid())
  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  email       String
  role        SupplierMemberRole @default(ADMIN)
  tokenHash   String             @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([supplierId])
  @@index([email])
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  category      String
  manufacturer  String
  icon          String
  imageUrl      String?
  priceCents    Int
  unit          String         @default("each")
  etaDays       Int
  stock         Int            @default(0)
  quoteOnly     Boolean        @default(false)
  description   String
  specs         Json
  // Freight inputs. Populated by the supplier on the listing form (and by
  // bulk CSV import where present). When weight + dims + freightClass are
  // all set on every line of an order, real-rate Shippo quotes light up;
  // otherwise the deterministic fallback in lib/freight.ts takes over.
  // freightClass values follow NMFC (50, 55, 60, 65, 70, 77.5, 85, 92.5,
  // 100, 110, 125, 150, 175, 200, 250, 300, 400, 500); stored as a string
  // because the codes aren't sequential integers.
  weightLbs     Float?
  freightClass  String?
  lengthIn      Float?
  widthIn       Float?
  heightIn      Float?
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  supplierId    String
  active        Boolean        @default(true)
  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
  reviews       Review[]
  images        ProductImage[]
  createdAt     DateTime       @default(now())
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Payout {
  id              String       @id @default(cuid())
  reference       String       @unique
  supplier        Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId      String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  // amountCents is what the supplier actually receives: subtotal share
  // minus reserve. reservedCents records what was held back, mirrored
  // onto Order.reservedCents for the buyer-facing order view.
  amountCents     Int
  reservedCents   Int          @default(0)
  status          PayoutStatus @default(DUE)
  // Stripe transfer id for the supplier portion. Null on legacy manual
  // payouts (pre-P8) and on payouts where Connect onboarding wasn't done.
  stripeTransferId String?     @unique
  // Number of retry attempts the payout-retry cron has burned; gives the
  // cron an exponential backoff and a stopping point.
  retryAttempts   Int          @default(0)
  lastRetryAt     DateTime?
  failureReason   String       @default("")
  note            String       @default("")
  createdAt       DateTime     @default(now())
  paidAt          DateTime?

  @@unique([supplierId, orderId])
  @@index([status])
}

/**
 * Audit trail for reserve holdback. Type values:
 *   HOLD       - amount held when a payout was created
 *   RELEASE    - amount released back to the supplier after the 60-day
 *                quiet window or admin manual release
 *   DRAW_DOWN  - amount pulled from the reserve to cover a refund or
 *                chargeback
 *
 * The running supplier balance is in Supplier.reserveBalanceCents; this
 * table is the per-transaction history.
 */
model SupplierReserveTransaction {
  id          String   @id @default(cuid())
  supplierId  String
  type        String   // HOLD | RELEASE | DRAW_DOWN
  amountCents Int
  orderId     String?
  reason      String   @default("")
  createdAt   DateTime @default(now())

  @@index([supplierId])
  @@index([orderId])
}

/**
 * Stripe refund records. One row per refund (a single order can have
 * multiple partial refunds). amountCents is positive; the running total
 * is mirrored onto Order.refundedCents for fast access on the order view.
 */
model Refund {
  id              String   @id @default(cuid())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  stripeRefundId  String?  @unique
  amountCents     Int
  reason          String   @default("")
  returnRequestId String?
  refundedBy      String?  // User.id of the admin who triggered it
  status          String   @default("succeeded") // succeeded | pending | failed
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([returnRequestId])
}

model ReturnRequest {
  id         String       @id @default(cuid())
  reference  String       @unique
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  buyerId    String?
  reason     String
  details    String       @default("")
  status     ReturnStatus @default(OPEN)
  adminNote  String       @default("")
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@index([orderId])
  @@index([status])
}

model Order {
  id                  String          @id @default(cuid())
  reference           String          @unique
  status              OrderStatus     @default(PENDING)
  buyer               User?           @relation(fields: [buyerId], references: [id])
  buyerId             String?
  buyerEmail          String
  buyerName           String
  // Snapshotted from User.companyName / User.companyLogoUrl at order
  // creation time so later profile edits never retroactively rewrite a
  // past invoice's branding.
  buyerCompanyName    String?
  buyerCompanyLogoUrl String?
  shipTo              String
  subtotalCents       Int
  freightCents        Int             @default(0)
  feeCents            Int
  taxCents            Int             @default(0)
  totalCents          Int
  feeRateBps          Int             @default(600)
  paymentMethod       String          @default("paypal")
  paypalOrderId       String?
  // Stripe payment_intent id captured from the checkout session webhook.
  // Required for the Stripe refund flow (P8 S4).
  stripePaymentIntentId String?
  // Running totals updated transactionally:
  //   refundedCents: sum of Refund rows; flips Order to REFUNDED at full.
  //   reservedCents: mirror of sum(Payout.reservedCents) for this order.
  refundedCents       Int             @default(0)
  reservedCents       Int             @default(0)
  shipmentStage       String          @default("")
  carrier             String?
  trackingCode        String?
  items               OrderItem[]
  invoice             Invoice?
  returns             ReturnRequest[]
  payouts             Payout[]
  refunds             Refund[]
  messages            Message[]
  reviews             Review[]
  createdAt           DateTime        @default(now())
  paidAt              DateTime?
  cancelledAt         DateTime?
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String        @unique
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  subtotalCents Int
  freightCents  Int
  feeCents      Int
  taxCents      Int
  totalCents    Int
  buyerName     String
  buyerEmail    String
  shipTo        String
}

model OrderItem {
  id             String  @id @default(cuid())
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  product        Product @relation(fields: [productId], references: [id])
  productId      String
  nameSnapshot   String
  skuSnapshot    String
  supplierName   String
  unitPriceCents Int
  qty            Int
}

model QuoteRequest {
  id              String      @id @default(cuid())
  reference       String      @unique
  product         Product     @relation(fields: [productId], references: [id])
  productId       String
  qty             Int         @default(1)
  buyerId         String?
  buyerName       String
  buyerEmail      String
  company         String      @default("")
  message         String      @default("")
  status          QuoteStatus @default(OPEN)
  quotedUnitCents Int?
  quoteNote       String      @default("")
  orderId         String?
  messages        Message[]
  createdAt       DateTime    @default(now())
  quotedAt        DateTime?
}

model Message {
  id          String        @id @default(cuid())
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String?
  quote       QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String?
  sender      User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderId    String?
  senderName  String
  senderEmail String
  senderRole  String
  body        String
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@index([quoteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String
  // Free-form string instead of an enum so we can introduce new actions
  // without a schema migration. Set of well-known values is enforced at
  // the lib/audit.ts boundary.
  action     String
  targetType String
  targetId   String
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/**
 * Per-US-state tax registration tracker. Stripe Tax computes liability
 * automatically; this table records where PartsPort has actually
 * registered to remit. Used by /admin/tax-registrations.
 */
model TaxRegistration {
  id                 String    @id @default(cuid())
  state              String    @unique  // "TX" | "CA" | etc.
  registrationStatus String    // NOT_REQUIRED | REQUIRED | REGISTERED | FILING
  registeredAt       DateTime?
  nextFilingDue      DateTime?
  notes              String    @default("")
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())
}

model SupplierApplication {
  id           String            @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  website      String            @default("")
  category     String
  yearsTrading String
  certs        String            @default("")
  message      String            @default("")
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
}
