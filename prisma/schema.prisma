generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
  MANUFACTURER
}

enum SupplierStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
}

enum QuoteStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum ReturnStatus {
  OPEN
  APPROVED
  REJECTED
  RESOLVED
}

enum PayoutStatus {
  DUE
  PAID
}

enum SupplierMemberRole {
  OWNER
  ADMIN
  SALES
  FULFILLMENT
  CATALOG
  FINANCE
  VIEWER
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String
  role                Role     @default(BUYER)
  manufacturerName    String?
  totpSecret          String?
  totpEnabledAt       DateTime?
  totpBackupCodes     Json?
  supplier            Supplier?
  orders              Order[]
  resetTokens         PasswordResetToken[]
  reviews             Review[]
  addresses           Address[]
  messages            Message[]
  supplierMemberships SupplierMember[]
  createdAt           DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Review {
  id         String   @id @default(cuid())
  buyer      User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId    String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  rating     Int
  body       String   @default("")
  createdAt  DateTime @default(now())

  @@unique([buyerId, productId])
  @@index([productId])
  @@index([supplierId])
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String   @default("")
  recipient  String
  company    String   @default("")
  line1      String
  line2      String   @default("")
  city       String
  region     String
  postalCode String
  country    String   @default("US")
  phone      String   @default("")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model Supplier {
  id             String         @id @default(cuid())
  name           String
  contactEmail   String
  status         SupplierStatus @default(APPROVED)
  rating         Float          @default(4.7)
  reviews        Int            @default(0)
  onTimeRate     Float          @default(97.5)
  certifications String         @default("")
  logoUrl        String?
  website        String         @default("")
  description    String         @default("")
  user           User?          @relation(fields: [userId], references: [id])
  userId         String?        @unique
  products       Product[]
  productReviews Review[]
  payouts        Payout[]
  members        SupplierMember[]
  invites        SupplierInvite[]
  createdAt      DateTime       @default(now())
}

model SupplierMember {
  id         String             @id @default(cuid())
  supplier   Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       SupplierMemberRole @default(ADMIN)
  createdAt  DateTime           @default(now())

  @@unique([supplierId, userId])
  @@index([userId])
}

model SupplierInvite {
  id          String             @id @default(cuid())
  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  email       String
  role        SupplierMemberRole @default(ADMIN)
  tokenHash   String             @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([supplierId])
  @@index([email])
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  category      String
  manufacturer  String
  icon          String
  imageUrl      String?
  priceCents    Int
  unit          String         @default("each")
  etaDays       Int
  stock         Int            @default(0)
  quoteOnly     Boolean        @default(false)
  description   String
  specs         Json
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  supplierId    String
  active        Boolean        @default(true)
  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
  reviews       Review[]
  images        ProductImage[]
  createdAt     DateTime       @default(now())
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Payout {
  id          String       @id @default(cuid())
  reference   String       @unique
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId  String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  amountCents Int
  status      PayoutStatus @default(DUE)
  note        String       @default("")
  createdAt   DateTime     @default(now())
  paidAt      DateTime?

  @@unique([supplierId, orderId])
  @@index([status])
}

model ReturnRequest {
  id           String       @id @default(cuid())
  reference    String       @unique
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  buyerId      String?
  reason       String
  details      String       @default("")
  status       ReturnStatus @default(OPEN)
  adminNote    String       @default("")
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?

  @@index([orderId])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  reference     String      @unique
  status        OrderStatus @default(PENDING)
  buyer         User?       @relation(fields: [buyerId], references: [id])
  buyerId       String?
  buyerEmail    String
  buyerName     String
  shipTo        String
  subtotalCents Int
  freightCents  Int         @default(0)
  feeCents      Int
  taxCents      Int         @default(0)
  totalCents    Int
  feeRateBps    Int         @default(400)
  paymentMethod String      @default("paypal")
  paypalOrderId String?
  shipmentStage String      @default("")
  carrier       String?
  trackingCode  String?
  items         OrderItem[]
  invoice       Invoice?
  returns       ReturnRequest[]
  payouts       Payout[]
  messages      Message[]
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String        @unique
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  subtotalCents Int
  freightCents  Int
  feeCents      Int
  taxCents      Int
  totalCents    Int
  buyerName     String
  buyerEmail    String
  shipTo        String
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product @relation(fields: [productId], references: [id])
  productId    String
  nameSnapshot String
  skuSnapshot  String
  supplierName String
  unitPriceCents Int
  qty          Int
}

model QuoteRequest {
  id              String      @id @default(cuid())
  reference       String      @unique
  product         Product     @relation(fields: [productId], references: [id])
  productId       String
  qty             Int         @default(1)
  buyerId         String?
  buyerName       String
  buyerEmail      String
  company         String      @default("")
  message         String      @default("")
  status          QuoteStatus @default(OPEN)
  quotedUnitCents Int?
  quoteNote       String      @default("")
  orderId         String?
  messages        Message[]
  createdAt       DateTime    @default(now())
  quotedAt        DateTime?
}

model Message {
  id          String        @id @default(cuid())
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String?
  quote       QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String?
  sender      User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderId    String?
  senderName  String
  senderEmail String
  senderRole  String
  body        String
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@index([quoteId])
}

model SupplierApplication {
  id           String            @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  website      String            @default("")
  category     String
  yearsTrading String
  certs        String            @default("")
  message      String            @default("")
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
}
