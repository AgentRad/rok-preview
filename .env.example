# --- Database (required) ---
# Easiest: in Vercel, open the project → Storage → Create Database → Neon Postgres.
# That integration sets DATABASE_URL and DATABASE_URL_UNPOOLED automatically.
# For local dev, point both at your local Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Session signing (optional) ---
# Falls back to an insecure default if unset; set a long random string for production.
SESSION_SECRET="generate-a-long-random-string"

# --- AI search (optional) ---
# Enables natural-language catalog search. Without it, keyword search is used.
ANTHROPIC_API_KEY=""

# --- Payments (optional) ---
# Enables real PayPal sandbox checkout. Without it, a built-in demo checkout is used.
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
